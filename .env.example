MIRRORBRAIN_HTTP_HOST=127.0.0.1
MIRRORBRAIN_HTTP_PORT=3007
# Required. Use an external workspace path, not the source repository.
MIRRORBRAIN_WORKSPACE_DIR=/path_to_workspace/mirrorbrain-workspace
MIRRORBRAIN_ACTIVITYWATCH_BASE_URL=http://127.0.0.1:5600
MIRRORBRAIN_BROWSER_BUCKET_ID=aw-watcher-web-chrome_laptop
MIRRORBRAIN_SYNC_INTERVAL_MS=3600000
MIRRORBRAIN_INITIAL_BACKFILL_HOURS=24

# OpenAI-compatible chat model used by MirrorBrain for candidate titles and knowledge synthesis.
MIRRORBRAIN_LLM_API_BASE=
MIRRORBRAIN_LLM_API_KEY=
MIRRORBRAIN_LLM_MODEL=

# Reserved OpenAI-compatible embedding model configuration for retrieval indexing.
MIRRORBRAIN_EMBEDDING_API_BASE=
MIRRORBRAIN_EMBEDDING_API_KEY=
MIRRORBRAIN_EMBEDDING_MODEL=

# Tavily search resource configuration.
MIRRORBRAIN_TAVILY_API_BASE=
MIRRORBRAIN_TAVILY_API_KEY=
MIRRORBRAIN_TAVILY_MAX_RESULTS=
